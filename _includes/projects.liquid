<div class="col">
  <div class="card h-100 hoverable project-card">
    {% if project.img %}
      {%
        include figure.liquid
        loading="eager"
        path=project.img
        sizes = "250px"
        alt="project thumbnail"
        class="card-img-top"
      %}
    {% endif %}
    <a href="{% if project.redirect %}{{ project.redirect }}{% else %}{{ project.url | relative_url }}{% endif %}" class="project-card-body-link">
      <div class="card-body">
        <h2 class="card-title project-card-title">{{ project.title }}</h2>
        <p class="card-text">{{ project.description }}</p>
      </div>
    </a>
    {% if project.github %}
      <div class="project-card-footer">
        <a href="{{ project.github }}" target="_blank" rel="noopener noreferrer" class="project-github-pill">
          <i class="fa-brands fa-github"></i>
          <span>View on GitHub</span>
        </a>
      </div>
    {% endif %}
  </div>
</div>
